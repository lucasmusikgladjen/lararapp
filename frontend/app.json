{
  "expo": {
    "name": "Musikglädjen",
    "slug": "musikgladjen",
    "version": "1.0.0",
    "scheme": "musikgladjen-app",
    "icon": "./assets/musikgladjen-ikon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "se.musikgladjen.lararapp",
      "splash": {
        "image": "./assets/splash.png",
        "resizeMode": "contain",
        "backgroundColor": "#ffffff"
      },
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSLocationWhenInUseUsageDescription": "Musikglädjen behöver din plats för att visa elever i ditt område."
      }
    },
    "notification": {
      "icon": "./assets/push-icon.png",
      "color": "#F59E0B"
    },
    "android": {
      "package": "se.musikgladjen.lararapp",
      "splash": {
        "image": "./assets/splash.png",
        "resizeMode": "contain",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "web": {
      "favicon": "",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Musikglädjen behöver din plats för att visa elever i ditt område."
        }
      ],
      "@react-native-community/datetimepicker"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "6846d076-73b6-4d2c-8407-4773ab1ac91d"
      }
    },
    "owner": "lucasmusikgladjen"
  }
}
